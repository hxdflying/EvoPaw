workspace:
  id: "evopaw-default"
  name: "EvoPaw 工作助手"

feishu:
  # 必填：从飞书开放平台应用配置中获取
  app_id: "${FEISHU_APP_ID}"
  app_secret: "${FEISHU_APP_SECRET}"
  # 可选：事件加密/验证相关配置，如未启用可留空
  encrypt_key: ""
  verification_token: ""

bot:
  loading_message: "思考中..."
  prefix: ""

agent:
  # 主 Agent 模型（Claude Sonnet 4.6）
  planner_model: "claude-sonnet-4-6"
  # Sub-Agent 模型（Claude Haiku 4.5，成本更低）
  sub_agent_model: "claude-haiku-4-5"
  max_turns: 50
  sub_agent_max_turns: 20
  timeout_s: 300

skills:
  global_dir: "../skills"
  local_dir: "./skills"

sandbox:
  # Claude Agent SDK 内置工具在容器内执行，无需外部沙箱
  type: claude_builtin
  workspace_dir: "/workspace"
  timeout_s: 120

memory:
  workspace_dir: "./data/workspace"
  ctx_dir: "./data/ctx"
  db_dsn: "${MEMORY_DB_DSN:-postgresql://evopaw:evopaw123@localhost:5432/evopaw_memory}"

session:
  max_history_turns: 20

runner:
  queue_idle_timeout_s: 300
  max_queue_size: 10

sender:
  max_retries: 3
  retry_backoff: [1, 2, 4]

data_dir: "./data"

debug:
  enable_test_api: false
  test_api_port: 9090
  test_api_host: "127.0.0.1"
