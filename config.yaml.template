workspace:
  id: "evopaw-default"
  name: "EvoPaw 工作助手"

feishu:
  # 必填：从飞书开放平台应用配置中获取
  app_id: "${FEISHU_APP_ID}"
  app_secret: "${FEISHU_APP_SECRET}"
  # 可选：事件加密/验证相关配置，如未启用可留空
  encrypt_key: ""
  verification_token: ""

bot:
  loading_message: "思考中..."
  prefix: ""

agent:
  # 主 Agent 模型（Claude Sonnet 4.6）
  planner_model: "claude-sonnet-4-6"
  # Sub-Agent 模型（Claude Haiku 4.5，成本更低）
  sub_agent_model: "claude-haiku-4-5"
  max_turns: 50
  sub_agent_max_turns: 20
  timeout_s: 300

skills:
  global_dir: "../skills"
  local_dir: "./skills"

sandbox:
  # Claude Agent SDK 内置工具在容器内执行，无需外部沙箱
  type: claude_builtin
  workspace_dir: "/workspace"
  timeout_s: 120

memory:
  workspace_dir: "./data/workspace"
  ctx_dir: "./data/ctx"
  # NOTE: Python 不展开 ${VAR:-default} 这种 bash 语法，必须填字面值。
  #   - 本地直跑（python3 -m evopaw.main）：host 用 localhost
  #   - docker compose 跑：host 改成服务名 evopaw-pgvector
  db_dsn: "postgresql://evopaw:evopaw123@localhost:5432/evopaw_memory"

session:
  max_history_turns: 20

runner:
  queue_idle_timeout_s: 300
  max_queue_size: 10
  # 重投递去重窗口（LRU，最近 N 条 msg_id）；0 表示关闭
  dedup_window_size: 256

# 语音识别（Fun-ASR 实时 WebSocket API，one-shot 模式）。
# DASHSCOPE_API_KEY 从环境变量读取，不在此处填写。
asr:
  enabled: true
  provider: "aliyun_funasr_realtime"
  # 上线前建议固定为官方快照号；下面是 2026-04-25 检索阿里云文档时列出的快照：
  #   - fun-asr-realtime-2026-02-28（最新）
  #   - fun-asr-realtime-2025-11-07（别名 fun-asr-realtime 当前指向此版本）
  #   - fun-asr-realtime-2025-09-15
  #   - fun-asr-flash-8k-realtime-2026-01-28（8kHz 模型，§18.2 方案 A 备选）
  # 实际上线前请到 https://help.aliyun.com/zh/model-studio/fun-asr-realtime-websocket-api
  # 复核当时最新发布的快照号，再写入此处。别名值会触发 _warn_if_model_is_alias 启动告警。
  model: "fun-asr-realtime"
  ws_url: "wss://dashscope.aliyuncs.com/api-ws/v1/inference/"
  audio_format: "opus"             # 飞书语音默认为 opus
  sample_rate: 16000               # fun-asr-realtime 要求 16kHz
  chunk_bytes: 1024                # 每次发送字节数
  chunk_interval_ms: 100           # 发送间隔（ms）
  submit_timeout_s: 10             # run-task → task-started 的超时
  max_wait_s: 120                  # 整次 one-shot 的硬上限
  max_reconnect_retries: 1         # 握手/连接级整次转写重试次数
  short_wait_s: 10                 # 语音转写超过此值触发回执
  long_audio_threshold_ms: 15000   # duration 超过此值立即发回执
  ack_text: "语音已收到，正在转写和分析，请稍候。"
  # 显示控制（设计文档 §9 / Phase 4 第 5 项）
  transcription_title: "语音转写"  # 回复中转写段标题
  answer_title: "回答"             # 回复中回答段标题
  display_transcript: true         # false 时回复仅含 Agent 答复，不展示转写
  include_audio_path: true         # false 时 Agent 不收到沙盒音频路径

sender:
  max_retries: 3
  retry_backoff: [1, 2, 4]

data_dir: "./data"

debug:
  enable_test_api: false
  test_api_port: 9090
  test_api_host: "127.0.0.1"
